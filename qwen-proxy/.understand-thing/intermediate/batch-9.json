      "complexity": "moderate"
    },
    {
      "id": "document:docs/architecture.md",
      "type": "document",
      "name": "architecture.md",
      "filePath": "docs/architecture.md",
      "summary": "Detailed architecture and implementation guide covering the request lifecycle from protocol adaptation through middleware, tool calling (DSML injection), account rotation (LRU + cooldown), proxy pool (4-tier priority + failover), ssxmod anti-crawling, data persistence (file/redis), and the React webui.",
      "tags": ["documentation", "architecture", "implementation-guide", "navigation-map"],
      "complexity": "complex"
    },
    {
      "id": "document:docs/cloudflare-workers.md",
      "type": "document",
      "name": "cloudflare-workers.md",
      "filePath": "docs/cloudflare-workers.md",
      "summary": "Compatibility roadmap for Cloudflare Workers deployment, listing missing Node.js APIs (http, fs, Express, axios) and outlining a 5-layer migration plan (network, persistence, framework, streaming, anti-crawl) with effort estimates and temporary alternatives.",
      "tags": ["documentation", "deployment", "cloudflare", "migration-roadmap"],
      "complexity": "simple"
    },
