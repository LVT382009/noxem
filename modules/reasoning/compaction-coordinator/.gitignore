node_modules/
webchat/node_modules/
marm-new-ui/node_modules/

# Python artifacts
venv/
env/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# MCP server database
marm-mcp-server/*.db
marm-mcp-server/marm_memory.db

# Logs and runtime data
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pids/
*.pid
*.seed
*.pid.lock
scripts/out/
marm-mcp-server/scripts/out/

# Local install-helper prototype; not public-ready.
scripts/mcp-client-commands.py
scripts/tests/test_mcp_client_commands.py

# Coverage
coverage/
*.lcov

# Build outputs
dist/
build/
.next/
.nuxt/

# Cache
.cache/
.parcel-cache/
.npm/
.eslintcache/
*.tsbuildinfo

# Temporary files
tmp/
temp/

# Editor and IDE files
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# Docker
.dockerignore

# Secrets and sensitive data
*.key
*.pem
config/secrets/
.aider*

# Documentation and local-only content
docs/publishing.md
docs/main-roadmap.md
docs/archived/
docs/core/
docs/current/
docs/future/

